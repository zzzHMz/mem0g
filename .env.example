# ===========================
# 0G Configuration
# ===========================
# 0G Compute Router (OpenAI-compatible)
# Mainnet: https://router-api.0g.ai/v1
# Testnet: https://router-api-testnet.integratenetwork.work/v1
OG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1
OG_API_KEY=sk-your-api-key-here

# 0G Storage
# Galileo Testnet RPC
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
OG_PRIVATE_KEY=your-private-key-here
OG_STORAGE_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296

# AI Model (any model available on 0G Compute Router)
# See full list: https://docs.0g.ai/developer-hub/building-on-0g/compute-network/router/models
OG_MODEL=openai/gpt-4o-mini

# ===========================
# Server
# ===========================
PORT=3000
DEMO_MODE=false
